#!/usr/bin/env bash
set -euo pipefail

# pre-commit — reject any commit that carries gitignored paths in the index.
#
# Why this exists:
#   Internal artifacts (MEMORY.md, FLOW.md, TECH-DEBT.md, .claude/, .agents/,
#   CLAUDE.md, AGENTS.md, .plans/, adr/, ENTERPRISE_LICENSE.md, CLA.md,
#   CONTRIBUTING.md, etc.) live in ~/proj/devflow/agentwrit/ or stay on disk
#   as gitignored files for Claude Code discovery. None of them should ever
#   enter this repo's git history on any branch.
#
#   .gitignore prevents accidental `git add .` from tracking them. This hook
#   is the narrow safety net against `git add -f <path>` — the only way a
#   gitignored path can actually slip into the index.
#
#   Replaces the old "strip dev files from main" model (deleted strip_for_main.sh
#   and main-hygiene gate). Runs on every branch, every commit — there is no
#   "safe branch" for these paths anymore.
#
# Install (one-time per clone):
#   git config core.hooksPath .githooks

# List cached (tracked) files that also match .gitignore patterns.
# Non-empty output = someone force-added a gitignored path and is about to commit it.
TRACKED_IGNORED=$(git ls-files -c --exclude-standard --ignored 2>/dev/null || true)

if [[ -n "$TRACKED_IGNORED" ]]; then
  echo ""
  echo "ERROR: refusing commit — gitignored paths are staged in the index:"
  echo ""
  echo "$TRACKED_IGNORED" | sed 's/^/  /'
  echo ""
  echo "These paths are gitignored and must not be committed on any branch."
  echo "If you truly need to track one of them, the correct fix is to remove"
  echo "the pattern from .gitignore, not to force-add past it."
  echo ""
  echo "To unstage: git rm --cached <path>  (keeps file on disk, removes from index)"
  echo ""
  exit 1
fi

exit 0
